HF_TOKEN=your_token_here

# Step 2 | Document
# https://console.mistral.ai/api-keys (used for Mistral STT + Mistral OCR)
MISTRAL_API_KEY=your_mistral_api_key_here

# Step 2 | Transcription - Local Files and Hosted URLs
# https://www.assemblyai.com/dashboard/signup
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Step 3 | LLM
OPENAI_API_KEY=your_openai_api_key_here
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Step 5 - 8 | Multimodal (Images, Video, Text-to-Speech, and Music)
# https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# https://platform.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key_here

# Logging
# human (pretty local logs), json (NDJSON for ingestion), both, auto (json in production, human otherwise)
AUTOSHOW_LOG_FORMAT=auto
# debug | info | success | warn | error
AUTOSHOW_LOG_LEVEL=info

# Step 1 | yt-dlp overrides
# See docs/cookies.md for cookie setup flows
# Optional: browser cookie import for YouTube bot-check/auth prompts, e.g. chrome, chrome:Default, firefox
# YTDLP_COOKIES_FROM_BROWSER=chrome
# Optional: exported cookies.txt path for yt-dlp. If this is set and readable, it takes precedence over YTDLP_COOKIES_FROM_BROWSER.
# YTDLP_COOKIES=/absolute/path/to/cookies.txt
# Optional: raw yt-dlp extractor args, e.g. youtube:player_client=tv or youtube:po_token=mweb.gvs+...
# YTDLP_EXTRACTOR_ARGS=
